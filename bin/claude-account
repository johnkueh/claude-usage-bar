#!/bin/sh
# claude-account — switch which Claude subscription this Mac's sessions/agents use,
# by swapping the Claude Code keychain login credential between saved snapshots.
#
#   claude-account snapshot work   # save the CURRENTLY logged-in account's credential as 'work'
#   claude-account work            # switch the Mac to the work account
#   claude-account personal        # switch the Mac to the personal account
#   claude-account status          # which account is active
#
# How it works: Claude Code stores its login in the macOS Keychain item
# "Claude Code-credentials". Snapshots live at ~/.claude/.cred-<name> (chmod 600).
# A switch first re-snapshots the live credential under the active account's name
# (so refreshed tokens are never lost), then writes the target snapshot into the
# keychain. New sessions/agents pick it up immediately; this is a real login, so
# Remote Control and everything else behave exactly as after /login.
#
# Setup (one-time):
#   1. claude-account snapshot <name-of-account-this-mac-is-logged-into>
#   2. /login as the other account in any Claude session
#   3. claude-account snapshot <other-name>
#   Thereafter: claude-account work|personal any time.

set -eu

SVC="Claude Code-credentials"
ACCT="$(whoami)"
DIR="$HOME/.claude"
MARKER="$DIR/.account-active"

die() { echo "claude-account: $*" >&2; exit 1; }

read_live() { security find-generic-password -w -s "$SVC" -a "$ACCT" 2>/dev/null; }

write_live() { security add-generic-password -U -s "$SVC" -a "$ACCT" -w "$1"; }

save_snapshot() { # $1=name $2=blob
  umask 077
  printf '%s' "$2" > "$DIR/.cred-$1"
}

LOCK="$DIR/.account-lock"
lock_acquire() {
  tries=0
  until mkdir "$LOCK" 2>/dev/null; do
    tries=$((tries + 1))
    [ "$tries" -gt 100 ] && die "another claude-account operation is in progress (stale lock? rm -rf '$LOCK')"
    sleep 0.1
  done
}
lock_release() { rmdir "$LOCK" 2>/dev/null || true; }

# Resolve the claude binary even under a minimal GUI PATH (the menu-bar app).
resolve_claude() {
  if command -v claude >/dev/null 2>&1; then command -v claude; return 0; fi
  for c in "$HOME/.local/bin/claude" /opt/homebrew/bin/claude /usr/local/bin/claude; do
    [ -x "$c" ] && { echo "$c"; return 0; }
  done
  return 1
}

# Run a command with a hard timeout (macOS has no `timeout` by default).
run_with_timeout() { # $1=secs, rest=cmd...
  _secs=$1; shift
  "$@" & _cmd_pid=$!
  ( sleep "$_secs"; kill "$_cmd_pid" 2>/dev/null ) & _killer=$!
  wait "$_cmd_pid" 2>/dev/null; _rc=$?
  kill "$_killer" 2>/dev/null
  return "$_rc"
}

# Write a saved snapshot back into the live keychain (used to restore the active
# account after a heartbeat that briefly swapped another account in).
restore_active() { # $1=active name
  [ -n "${1:-}" ] && [ -f "$DIR/.cred-$1" ] && write_live "$(cat "$DIR/.cred-$1")" || true
}

# Is $1 a process-ancestor of this script? Used so a bounce never kills the
# session/app that invoked the switch.
is_ancestor() { # $1=candidate pid
  _p=$$
  while [ "${_p:-0}" -gt 1 ]; do
    [ "$_p" = "$1" ] && return 0
    _p=$(ps -o ppid= -p "$_p" 2>/dev/null | tr -d ' ')
    [ -n "$_p" ] || break
  done
  return 1
}

case "${1:-status}" in
  snapshot)
    name="${2:-}"
    [ -n "$name" ] || die "usage: claude-account snapshot <name>"
    blob=$(read_live) || die "could not read the live credential — is Claude Code logged in?"
    [ -n "$blob" ] || die "live credential is empty"
    save_snapshot "$name" "$blob"
    printf '%s' "$name" > "$MARKER"
    echo "snapshotted live credential as '$name' (active account marker set)"
    ;;
  refresh)
    # Heartbeat: refresh an inactive account's OAuth access token WITHOUT a manual
    # switch. For each target, briefly load its snapshot into the keychain, run a tiny
    # `claude -p` (which makes Claude Code refresh the expired token via its refresh
    # token and write the new credential back), re-snapshot the fresh credential, then
    # restore the active account. The keychain is swapped only for the seconds claude -p
    # runs; a lock guards against a concurrent switch/refresh. Default targets = all
    # inactive accounts. This is what kills the "switch once to refresh" stale gauge.
    shift || true
    claude_bin=$(resolve_claude) || die "claude binary not found (looked on PATH and ~/.local/bin)"
    [ -f "$MARKER" ] || die "active account unknown — run: claude-account snapshot <current-name> first"
    active=$(cat "$MARKER")
    if [ "$#" -gt 0 ]; then
      targets="$*"
    else
      targets=""
      for f in "$DIR"/.cred-*; do
        [ -e "$f" ] || continue
        n=${f##*/.cred-}
        [ "$n" = "$active" ] || targets="$targets $n"
      done
    fi
    [ -n "$(printf '%s' "$targets" | tr -d ' ')" ] || { echo "no inactive accounts to refresh"; exit 0; }

    lock_acquire
    trap 'restore_active "$active"; lock_release' EXIT INT TERM
    live=$(read_live) || die "could not read live credential"
    [ -n "$live" ] || die "live credential empty; aborting"
    save_snapshot "$active" "$live"   # preserve active's current (possibly refreshed) cred

    for name in $targets; do
      [ "$name" = "$active" ] && { echo "skip '$name' (active — already live)"; continue; }
      [ -f "$DIR/.cred-$name" ] || { echo "skip '$name' (no snapshot)"; continue; }
      write_live "$(cat "$DIR/.cred-$name")"
      run_with_timeout 60 "$claude_bin" -p 'ok' --max-turns 1 >/dev/null 2>&1 || true
      newblob=$(read_live || true)
      # Only overwrite the snapshot if the refresh actually produced a credential
      # with a non-empty access token — a failed refresh must never degrade a good
      # (merely expired, still-refreshable) snapshot. grep, not jq, to stay
      # PATH-independent under the menu-bar app's minimal GUI environment.
      if printf '%s' "$newblob" | grep -Eq '"accessToken" *: *"[^"]'; then
        save_snapshot "$name" "$newblob"
        echo "refreshed '$name'"
      else
        echo "warn: '$name' refresh produced no valid access token — left existing snapshot untouched"
      fi
    done
    restore_active "$active"   # belt-and-braces; trap restores again on exit
    ;;
  usage)
    # Show 5-hour + weekly utilization for every snapshotted account, so you can
    # pick an account by remaining quota without switching. Uses access tokens
    # only (read-only); the inactive account's token can expire (~daily) — a
    # switch to it refreshes the snapshot.
    command -v jq >/dev/null || die "jq required"
    active=$(cat "$MARKER" 2>/dev/null || echo "")
    printf '%-12s %8s %8s  %s\n' "account" "5h-used" "wk-used" "weekly-resets"
    for f in "$DIR"/.cred-*; do
      [ -e "$f" ] || die "no snapshots found"
      name=${f##*/.cred-}
      if [ "$name" = "$active" ]; then
        tok=$(read_live | jq -r '.claudeAiOauth.accessToken // empty'); tag="$name*"
      else
        tok=$(jq -r '.claudeAiOauth.accessToken // empty' "$f"); tag="$name"
      fi
      [ -n "$tok" ] || { printf '%-12s %s\n' "$tag" "(no token)"; continue; }
      resp=$(curl -sS --max-time 10 https://api.anthropic.com/api/oauth/usage \
        -H "Authorization: Bearer $tok" -H "anthropic-beta: oauth-2025-04-20")
      if printf '%s' "$resp" | jq -e '.seven_day' >/dev/null 2>&1; then
        printf '%s' "$resp" | jq -r --arg n "$tag" \
          '[$n, "\(.five_hour.utilization // 0)%", "\(.seven_day.utilization // 0)%", ((.seven_day.resets_at // "?") | sub("\\.[0-9]+";"") )] | @tsv' \
          | awk -F'\t' '{printf "%-12s %8s %8s  %s\n", $1, $2, $3, $4}'
      else
        printf '%-12s %s\n' "$tag" "(token expired — run: claude-account refresh $name)"
      fi
    done
    ;;
  whoami)
    # Empirically resolve which account the LIVE keychain credential belongs to,
    # via the same OAuth profile endpoint Claude Code's /status uses. Read-only;
    # never touches refresh tokens.
    blob=$(read_live) || die "could not read the live credential"
    tok=$(printf '%s' "$blob" | jq -r '.claudeAiOauth.accessToken // empty')
    [ -n "$tok" ] || die "no claudeAiOauth access token in the live credential"
    email=$(curl -sS --max-time 10 https://api.anthropic.com/api/oauth/profile \
      -H "Authorization: Bearer $tok" -H "anthropic-beta: oauth-2025-04-20" \
      | jq -r '.account.email // .email // "unknown (token may be expired)"')
    [ -f "$MARKER" ] && echo "marker:   $(cat "$MARKER")"
    echo "keychain: $email"
    ;;
  status)
    if [ -f "$MARKER" ]; then
      active=$(cat "$MARKER")
      live=$(read_live || true)
      if [ -f "$DIR/.cred-$active" ] && [ "$live" != "$(cat "$DIR/.cred-$active")" ]; then
        note=" (live credential has refreshed since last snapshot — normal)"
      else
        note=""
      fi
      echo "active: $active$note"
    else
      echo "active: unknown — run: claude-account snapshot <name> while logged into that account"
    fi
    ls "$DIR"/.cred-* >/dev/null 2>&1 && echo "snapshots: $(ls "$DIR"/.cred-* | sed 's|.*/\.cred-||' | tr '\n' ' ')"
    ;;
  *)
    name="$1"
    [ -f "$DIR/.cred-$name" ] || die "no snapshot for '$name' — run: claude-account snapshot $name while logged into it"
    [ -f "$MARKER" ] || die "active account unknown — run: claude-account snapshot <current-name> first"
    active=$(cat "$MARKER")
    [ "$active" != "$name" ] || { echo "already on '$name'"; exit 0; }
    lock_acquire
    trap 'lock_release' EXIT INT TERM
    # preserve the live (possibly refreshed) credential under the active name
    blob=$(read_live) || die "could not read live credential"
    [ -n "$blob" ] || die "live credential is empty; aborting"
    save_snapshot "$active" "$blob"
    write_live "$(cat "$DIR/.cred-$name")"
    printf '%s' "$name" > "$MARKER"
    echo "switched: Mac is now on '$name' — new sessions/agents use it (running ones keep their old account)"
    # The `claude agents` UI caches its account at startup and stamps it onto agents
    # it spawns — bounce it so respawns/new spawns pick up the new account. Exact
    # cmdline match only: claimed --bg-spare session processes must NOT be touched.
    # Ancestor-aware: kill every agents UI EXCEPT one that is a process-ancestor of
    # this switch (killing our own ancestor would take down the session/app that ran
    # the switch). This is safe even inside a Claude session (CLAUDECODE), as long as
    # the session wasn't launched from the very UI being bounced.
    bounced=0 parent_ui=0
    for pid in $(pgrep -fx 'claude agents' 2>/dev/null || true); do
      if is_ancestor "$pid"; then
        parent_ui=1
      else
        kill "$pid" 2>/dev/null && bounced=$((bounced + 1))
      fi
    done
    [ "$bounced" -gt 0 ] && echo "bounced the claude agents UI ($bounced) — reopen with \`claude agents\` on '$name'; running agents unaffected"
    [ "$parent_ui" = 1 ] && echo "the claude agents UI that launched this session is still on the old account — restart it when convenient so newly-spawned agents use '$name'"
    ;;
esac
